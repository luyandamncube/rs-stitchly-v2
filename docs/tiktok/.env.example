# Copy to docs/tiktok/.env.tiktok, fill locally, then source it before running scripts.
# Do not commit real values.

export TIKTOK_CLIENT_KEY="your_client_key"
export TIKTOK_CLIENT_SECRET="your_client_secret"

# Web/Vercel callback flow.
export TIKTOK_OAUTH_MODE="web"
export TIKTOK_REDIRECT_URI="https://YOUR-VERCEL-PROJECT.vercel.app/api/callback"

# Required for automatic code capture/polling. Deploy docs/tiktok/vercel or
# equivalent postbox endpoints, then set this to its /api/code URL.
export TIKTOK_CALLBACK_CODE_URL="https://YOUR-VERCEL-PROJECT.vercel.app/api/code"
export TIKTOK_CODE_POLL_TIMEOUT_SECONDS="180"
export TIKTOK_CODE_POLL_INTERVAL_SECONDS="3"
export TIKTOK_OPEN_BROWSER="false"

# Keep comma-separated, no spaces.
export TIKTOK_SCOPES="user.info.basic,video.list"

# Optional. You can pass the code as an argument instead.
export TIKTOK_AUTH_CODE=""

# Optional overrides.
export TIKTOK_OUT_DIR="docs/tiktok/out"
export TIKTOK_TOKEN_FILE="docs/tiktok/out/tiktok_tokens.json"
