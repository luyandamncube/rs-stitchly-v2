# Copy to tests/tiktok/.env and fill only the mechanisms you want to test.

# Local downloader probe.
ENABLE_MEDIA_DOWNLOAD=false

# TikTok Display API. Requires user OAuth and video list scope.
TIKTOK_ACCESS_TOKEN=

# TikTok Research API. Requires approved research API access.
TIKTOK_RESEARCH_ACCESS_TOKEN=
TIKTOK_RESEARCH_QUERY=tiktok

# Optional SaaS/vendor downloader smoke tests can use this later.
TIKTOK_VENDOR_API_URL=
TIKTOK_VENDOR_API_KEY=
