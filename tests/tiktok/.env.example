# Copy to tests/tiktok/.env and fill only the mechanisms you want to test.

# Local downloader probe.
ENABLE_MEDIA_DOWNLOAD=false

# TikTok Login Kit / OAuth.
# These come from the TikTok developer app. Use the sandbox values when testing
# against the sandbox app.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Must exactly match a redirect URI configured for the app's Login Kit product.
# TikTok's Web Login docs require HTTPS redirect URIs for web apps.
TIKTOK_REDIRECT_URI=https://example.com/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.list
TIKTOK_AUTH_CODE=
TIKTOK_REFRESH_TOKEN=

# TikTok Display API. Requires user OAuth and video list scope.
TIKTOK_ACCESS_TOKEN=

# TikTok Research API. Requires approved research API access.
TIKTOK_RESEARCH_ACCESS_TOKEN=
TIKTOK_RESEARCH_QUERY=tiktok

# Optional SaaS/vendor downloader smoke tests can use this later.
TIKTOK_VENDOR_API_URL=
TIKTOK_VENDOR_API_KEY=
